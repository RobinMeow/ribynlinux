#!/usr/bin/env bash
set -euo pipefail

source "$RIBYN_ROOT/lib/utils.sh"

echo "Syncing from source: $RIBYN_ROOT"

info "Syncing zsh"
"$RIBYN_ROOT/apps/zsh/sync.sh"

info "Syncing git"
"$RIBYN_ROOT/apps/git/sync.sh"

info "Syncing bat"
"$RIBYN_ROOT/apps/bat/sync.sh"

info "Syncing btop"
"$RIBYN_ROOT/apps/btop/sync.sh"

info "Syncing kitty"
"$RIBYN_ROOT/apps/kitty/sync.sh"

info "Syncing wezterm"
"$RIBYN_ROOT/apps/wezterm/sync.sh"

info "Syncing nvim"
"$RIBYN_ROOT/apps/nvim/sync.sh"

info "Syncing vale"
"$RIBYN_ROOT/apps/vale/sync.sh"

info "Syncing tmux"
"$RIBYN_ROOT/apps/tmux/sync.sh"

info "Syncing yazi"
"$RIBYN_ROOT/apps/yazi/sync.sh"

info "Syncing mpd"
"$RIBYN_ROOT/apps/mpd/sync.sh"

info "Syncing rmpc"
"$RIBYN_ROOT/apps/rmpc/sync.sh"

info "Syncing zathura"
"$RIBYN_ROOT/apps/zathura/sync.sh"

full_install=false
for arg in "$@"; do
	if [[ "$arg" == "--full-install" ]]; then
		full_install=true
	fi
done

for arg in "$@"; do
	if [[ "$arg" == "--pm" || $full_install ]]; then
		info "Syncing core"
		"$RIBYN_ROOT/scripts/pm-core.sh"
	fi

	if [[ "$arg" == "--webdev" || $full_install ]]; then
		info "Syncing gadgets"
		"$RIBYN_ROOT/scripts/pm-gadgets.sh"
	fi

	if [[ "$arg" == "--gadgets" ]]; then
		info "Syncing gadgets"
		"$RIBYN_ROOT/scripts/pm-gadgets.sh"
	fi

	if [[ "$arg" == "--kde" ]]; then
		info "Syncing kde"
		"$RIBYN_ROOT/apps/kde/sync.sh"
	fi

	if [[ "$arg" == "--hypr" ]]; then
		info "Syncing rofi"
		"$RIBYN_ROOT/apps/rofi/sync.sh"

		info "Syncing waybar"
		"$RIBYN_ROOT/apps/waybar/sync.sh"

		info "Syncing hypr"
		"$RIBYN_ROOT/apps/hypr/sync.sh"
	fi
done

success "ribynslinux installed"
