#!/usr/bin/env bash
set -euo pipefail

source "$RIBYN_ROOT/lib/utils.sh"

COMMENT="${1:-}"

if [[ -z "$COMMENT" ]]; then
	error "Comment is required as the first argument"
	exit 1
fi

ssh-keygen -t rsa -b 4096 -C "$COMMENT"
ssh-keyscan -H github.com >>~/.ssh/known_hosts
ssh-keyscan -H codeberg.org >>~/.ssh/known_hosts
