#!/usr/bin/env bash
set -euo pipefail

source "$RIBYNS_ENV/lib/utils.sh"

echo "Installing from source: $RIBYNS_ENV"

info "Installing zsh"
"$RIBYNS_ENV/zsh/install.sh"

# TODO: first run fails. r-rf m the dest dir, rerun manually and it succeeds..
info "Installing CommitMono"
"$RIBYNS_ENV/installers/install-commit-mono.sh"

info "Installing git"
"$RIBYNS_ENV/git/install.sh"

info "Installing bat"
"$RIBYNS_ENV/bat/install.sh"

info "Installing btop"
"$RIBYNS_ENV/btop/install.sh"

info "Installing kitty"
"$RIBYNS_ENV/kitty/install.sh"

info "Installing wezterm"
"$RIBYNS_ENV/wezterm/install.sh"

info "Installing nvim"
"$RIBYNS_ENV/nvim/install.sh"

info "Installing vale"
"$RIBYNS_ENV/vale/install.sh"

info "Installing tmux"
"$RIBYNS_ENV/tmux/install.sh"

info "Installing yazi"
"$RIBYNS_ENV/yazi/install.sh"

info "Installing mpd"
"$RIBYNS_ENV/mpd/install.sh"

info "Installing rmpc"
"$RIBYNS_ENV/rmpc/install.sh"

info "Installing zathura"
"$RIBYNS_ENV/zathura/install.sh"

full_install=false
for arg in "$@"; do
	if [[ "$arg" == "--full-install" ]]; then
		full_install=true
	fi
done

for arg in "$@"; do
	if [[ "$arg" == "--pm" || $full_install ]]; then
		info "Installing core"
		"$RIBYNS_ENV/scripts/pm-core.sh"
	fi

	if [[ "$arg" == "--webdev" || $full_install ]]; then
		info "Installing gadgets"
		"$RIBYNS_ENV/scripts/pm-gadgets.sh"
	fi

	if [[ "$arg" == "--gadgets" ]]; then
		info "Installing gadgets"
		"$RIBYNS_ENV/scripts/pm-gadgets.sh"
	fi

	if [[ "$arg" == "--kde" ]]; then
		info "Installing kde"
		"$RIBYNS_ENV/kde/install.sh"
	fi

	if [[ "$arg" == "--hypr" ]]; then
		info "Installing rofi"
		"$RIBYNS_ENV/rofi/install.sh"

		info "Installing waybar"
		"$RIBYNS_ENV/waybar/install.sh"

		info "Installing hypr"
		"$RIBYNS_ENV/hypr/install.sh"
	fi
done

success "ribyns-env installed"
