#!/usr/bin/env bash
set -euo pipefail

source "$RIBYN_ROOT/lib/utils.sh"

echo "Installing from source: $RIBYN_ROOT"

info "Installing zsh"
"$RIBYN_ROOT/apps/zsh/install.sh"

info "Installing CommitMono"
"$RIBYN_ROOT/installers/install-commit-mono.sh"

info "Installing git"
"$RIBYN_ROOT/apps/git/install.sh"

info "Installing bat"
"$RIBYN_ROOT/apps/bat/install.sh"

info "Installing btop"
"$RIBYN_ROOT/apps/btop/install.sh"

info "Installing kitty"
"$RIBYN_ROOT/apps/kitty/install.sh"

info "Installing wezterm"
"$RIBYN_ROOT/apps/wezterm/install.sh"

info "Installing nvim"
"$RIBYN_ROOT/apps/nvim/install.sh"

info "Installing vale"
"$RIBYN_ROOT/apps/vale/install.sh"

info "Installing tmux"
"$RIBYN_ROOT/apps/tmux/install.sh"

info "Installing yazi"
"$RIBYN_ROOT/apps/yazi/install.sh"

info "Installing mpd"
"$RIBYN_ROOT/apps/mpd/install.sh"

info "Installing rmpc"
"$RIBYN_ROOT/apps/rmpc/install.sh"

info "Installing zathura"
"$RIBYN_ROOT/apps/zathura/install.sh"

info "Installing bluetui"
"$RIBYN_ROOT/apps/bluetui/install.sh"

full_install=false
for arg in "$@"; do
	if [[ "$arg" == "--full-install" ]]; then
		full_install=true
	fi
done

for arg in "$@"; do
	if [[ "$arg" == "--pm" || $full_install ]]; then
		info "Installing core"
		"$RIBYN_ROOT/scripts/pm-core.sh"
	fi

	if [[ "$arg" == "--webdev" || $full_install ]]; then
		info "Installing gadgets"
		"$RIBYN_ROOT/scripts/pm-gadgets.sh"
	fi

	if [[ "$arg" == "--gadgets" ]]; then
		info "Installing gadgets"
		"$RIBYN_ROOT/scripts/pm-gadgets.sh"
	fi

	if [[ "$arg" == "--kde" ]]; then
		info "Installing kde"
		"$RIBYN_ROOT/apps/kde/install.sh"
	fi

	if [[ "$arg" == "--hypr" ]]; then
		info "Installing rofi"
		"$RIBYN_ROOT/apps/rofi/install.sh"

		info "Installing waybar"
		"$RIBYN_ROOT/apps/waybar/install.sh"

		info "Installing hypr"
		"$RIBYN_ROOT/apps/hypr/install.sh"
	fi
done

success "ribynliniux installed"
